# ==========================================================
# Cabinet de Réflexologie de l'Audomarois — Configuration serveur
# ==========================================================

# --- Fichier par défaut ---
DirectoryIndex index.html

# --- Encodage UTF-8 par défaut ---
AddDefaultCharset UTF-8

# --- Redirection 301 des vieilles URLs WordPress ---
# Les anciennes URLs (indexées par Google) sont redirigées vers la
# section correspondante du nouveau site en une seule page.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # --- Force HTTPS ---
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- Redirections thématiques (WordPress → sections du nouveau site) ---

    # Contact
    RewriteRule ^contact/?$ /#contact [R=301,L,NE]
    RewriteRule ^contactez-moi/?$ /#contact [R=301,L,NE]
    RewriteRule ^nous-contacter/?$ /#contact [R=301,L,NE]

    # À propos / Caroline
    RewriteRule ^author/caroline/?$ /#apropos [R=301,L,NE]
    RewriteRule ^a-propos/?$ /#apropos [R=301,L,NE]
    RewriteRule ^qui-suis-je/?$ /#apropos [R=301,L,NE]
    RewriteRule ^caroline/?$ /#apropos [R=301,L,NE]
    RewriteRule ^caroline-saintenoy/?$ /#apropos [R=301,L,NE]

    # Prestations / Soins
    RewriteRule ^prestations?/?$ /#soins [R=301,L,NE]
    RewriteRule ^soins?/?$ /#soins [R=301,L,NE]
    RewriteRule ^nos-soins/?$ /#soins [R=301,L,NE]
    RewriteRule ^services?/?$ /#soins [R=301,L,NE]

    # Types de réflexologie
    RewriteRule ^(la-)?reflexologie-plantaire/?$ /#soins [R=301,L,NE]
    RewriteRule ^onco-reflexologie/?$ /#soins [R=301,L,NE]
    RewriteRule ^reflexologie-pediatrique/?$ /#soins [R=301,L,NE]
    RewriteRule ^reflexologie-handicap/?$ /#soins [R=301,L,NE]
    RewriteRule ^reiki/?$ /#soins [R=301,L,NE]
    RewriteRule ^lhypnose/?$ / [R=301,L,NE]
    RewriteRule ^hypnose/?$ / [R=301,L,NE]
    RewriteRule ^univers-bebe/?$ / [R=301,L,NE]
    RewriteRule ^portage(-en-echarpe)?/?$ / [R=301,L,NE]

    # Tarifs
    RewriteRule ^tarifs?/?$ /#tarifs [R=301,L,NE]
    RewriteRule ^prix/?$ /#tarifs [R=301,L,NE]

    # Bienfaits
    RewriteRule ^bienfaits/?$ /#bienfaits [R=301,L,NE]

    # Formations
    RewriteRule ^formations?/?$ /#formations [R=301,L,NE]

    # Accueil / Bienvenue
    RewriteRule ^bienvenue/?$ / [R=301,L,NE]
    RewriteRule ^accueil/?$ / [R=301,L,NE]
    RewriteRule ^home/?$ / [R=301,L,NE]

    # Articles / Blog / Presse
    RewriteRule ^articles?(-de-presse)?/?$ / [R=301,L,NE]
    RewriteRule ^blog/?$ / [R=301,L,NE]
    RewriteRule ^presse/?$ / [R=301,L,NE]

    # --- Catch-all : toute autre URL inexistante → accueil ---
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/$
    RewriteRule ^.*$ / [R=301,L]
</IfModule>

# --- Compression Gzip (accélère le chargement) ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Cache navigateur (accélère les visites répétées) ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # HTML : cache court pour récupérer rapidement les mises à jour
    ExpiresByType text/html "access plus 1 hour"

    # Images : cache long
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS / JS : cache long
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"

    # Polices
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# --- Sécurité : masquer les fichiers sensibles ---
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

# --- En-têtes de sécurité de base ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
